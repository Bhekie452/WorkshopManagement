# Workshop Management System - Environment Variables
# Copy this file to .env.local and fill in your values

# ==================== API Configuration ====================

# Backend API URL (required for production deployment)
# For local development: leave empty (uses Vite proxy)
# For production: set to your deployed backend URL (e.g., https://your-backend.ucr.run)
VITE_API_URL=

# ==================== REQUIRED ====================

# Google Gemini API Key (for AI Diagnostics)
# Get it from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key

# ==================== EMAIL (SendGrid) ====================

# Email Server URL (for local development)
# Run with: npm run email-server
VITE_EMAIL_SERVER_URL=http://localhost:3001

# SendGrid API Key
# Get it from: https://app.sendgrid.com/settings/api_keys
VITE_SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Verified sender email
VITE_SENDGRID_FROM_EMAIL=info@yourworkshop.co.za

# ==================== PAYMENTS (PayFast) ====================

# PayFast Merchant ID
VITE_PAYFAST_MERCHANT_ID=10000100

# PayFast Merchant Key
VITE_PAYFAST_MERCHANT_KEY=your_merchant_key

# PayFast Passphrase (set in PayFast dashboard)
VITE_PAYFAST_PASSPHRASE=your_passphrase

# Sandbox mode (true for testing, false for production)
VITE_PAYFAST_SANDBOX=true
