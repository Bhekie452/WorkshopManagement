# =====================================================
# GOOGLE GEMINI AI (for AI Diagnostics)
# Get API key from: https://aistudio.google.com/app/apikey
# =====================================================
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# =====================================================
# EMAIL SERVER (SendGrid)
# =====================================================

# Local email server URL (do not change)
VITE_EMAIL_SERVER_URL=http://localhost:3001

# SendGrid API Key
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=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

# Verified sender email (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=bhekitsabedze452@gmail.com
VITE_SENDGRID_FROM_EMAIL=bhekitsabedze452@gmail.com
# =====================================================
# PAYFAST PAYMENTS (South Africa)
# =====================================================

# PayFast Merchant ID
# Get from: https://www.payfast.co.za.za/sandbox/merchant/settings/
VITE_PAYFAST_MERCHANT_ID=10000100

# PayFast Merchant Key
VITE_PAYFAST_MERCHANT_KEY=YOUR_PAYFAST_MERCHANT_KEY_HERE

# PayFast Passphrase (set in PayFast dashboard)
VITE_PAYFAST_PASSPHRASE=YOUR_PAYFAST_PASSPHRASE_HERE

# Sandbox mode: true = testing, false = production
VITE_PAYFAST_SANDBOX=true

